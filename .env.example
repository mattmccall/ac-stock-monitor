# Copy to .env for local testing (never commit the real .env).
# Create a bot with @BotFather to get the token.
# Get your chat id by messaging the bot, then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  -> result[].message.chat.id
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=987654321
